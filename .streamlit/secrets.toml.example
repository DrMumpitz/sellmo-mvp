# ============================================================
# Streamlit Secrets · Template
# ============================================================
# In Streamlit Cloud: über "Advanced settings" → "Secrets"
# eintragen. NICHT als Datei ins Repo committen (secrets.toml
# ist in .gitignore).
#
# Lokal für Beta-Test: cp secrets.toml.example secrets.toml
# und Werte einsetzen.
# ============================================================

# --- Anthropic API Key ---
# Aus console.anthropic.com/keys — auf Deinen Account gebunden.
# Alle KI-Calls der Beta-Tester werden über diesen Key abgerechnet.
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# --- Beta-Mode Toggle ---
# true  = URL-Token-Gate aktiv (Beta-Preview für Tester)
# false = klassische Login-Wall mit users.yaml
BETA_MODE = true

# --- Beta-Tokens ---
# Kommaseparierte Liste erlaubter Access-Tokens.
# Jeder Tester kriegt EINEN Token → URL wird:
#   https://sellmo-mvp.streamlit.app/?k=SELLMO-BETA-9K3M
# Wenn ein Token leakt: hier rausnehmen, neu deployen.
BETA_TOKENS = "SELLMO-BETA-9K3M,SELLMO-BETA-2X7P"
